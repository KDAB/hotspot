ARG BASEIMAGE="you-must-set-a-BASEIMAGE"
FROM $BASEIMAGE

LABEL org.opencontainers.image.source=https://github.com/kdab/hotspot
LABEL org.opencontainers.image.licenses=MIT

ARG PRESET

WORKDIR /opt

ADD . /opt/hotspot/

RUN cd hotspot && \
    cmake --preset $PRESET && \
    cmake --build --preset $PRESET
